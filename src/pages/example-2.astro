---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
import heroLoop from '../assets/hero-loop.mp4';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Bio-Hacker · Ciencia y Precisión" description="Método VFitness basado en evidencia. Nutrición clínica y planes personalizados online.">
  <div class="min-h-screen bg-bio-white font-sans text-bio-blue antialiased">
    <header class="sticky top-0 z-50 border-b border-bio-grey bg-bio-white/95 backdrop-blur transition-all" id="main-header">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-4 md:px-8">
        <a href="/example-2" class="font-serif text-lg font-semibold text-bio-blue">VFitness</a>
        <nav class="hidden gap-8 text-sm text-bio-blue/80 md:flex">
          <a href="/example-2#metodo" class="hover:text-bio-green">Método</a>
          <a href="/example-2#planes" class="hover:text-bio-green">Planes</a>
          <a href="/example-2#ubicacion" class="hover:text-bio-green">Ubicación</a>
          <a href="/example-2#contacto" class="hover:text-bio-green">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/example-2#planes" class="rounded-full border-2 border-bio-green bg-bio-green/5 px-5 py-2.5 text-sm font-medium text-bio-green transition hover:bg-bio-green/10 md:inline-flex">Solicitar consulta</a>
          <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-bio-grey text-bio-blue md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open">☰</span>
            <span class="menu-icon-close hidden">✕</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t border-bio-grey bg-bio-white px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-3 text-sm">
          <a href="/example-2#metodo" class="py-2 text-bio-blue/80 hover:text-bio-green">Método</a>
          <a href="/example-2#planes" class="py-2 text-bio-blue/80 hover:text-bio-green">Planes</a>
          <a href="/example-2#ubicacion" class="py-2 text-bio-blue/80 hover:text-bio-green">Ubicación</a>
          <a href="/example-2#contacto" class="py-2 text-bio-blue/80 hover:text-bio-green">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[100vh] overflow-hidden border-b border-bio-grey" id="hero">
        <div class="absolute inset-0 z-0">
          <video class="h-full w-full object-cover blur-sm" autoplay loop muted playsinline aria-hidden="true" src={typeof heroLoop === 'string' ? heroLoop : heroLoop.src} />
        </div>
        <div class="absolute inset-0 z-[1] bg-bio-white/85" aria-hidden="true" />
        <div class="absolute right-0 top-1/2 z-[1] h-64 w-64 -translate-y-1/2 rounded-full bg-bio-green/5 blur-3xl" aria-hidden="true" />
        <div class="relative z-10 flex min-h-[100vh] flex-col justify-center px-4 py-24 md:px-8">
          <div class="mx-auto w-full max-w-2xl">
            <p class="text-xs font-medium uppercase tracking-widest text-bio-green">Evidencia científica</p>
            <h1 class="mt-6 font-serif text-4xl font-semibold leading-tight text-bio-blue sm:text-5xl md:text-6xl">
              Cada caloría, cada repetición.<br />
              <span class="text-bio-green">Respaldados por ciencia.</span>
            </h1>
            <p class="mt-8 text-base leading-relaxed text-bio-blue/80">
              Método simple y muy efectivo: metabolismo basal, macronutrientes adaptados y plan de entrenamiento específico. Más de 7.000 cambios.
            </p>
            <a href="/example-2#planes" class="mt-10 inline-flex rounded-full bg-bio-green px-6 py-3.5 text-sm font-medium text-white transition hover:bg-bio-green/90">Ver planes</a>
            <div class="mt-20 flex flex-wrap gap-12 border-t border-bio-grey pt-10">
              <div><p class="text-2xl font-semibold tabular-nums text-bio-green md:text-3xl">7.000+</p><p class="mt-1 text-sm text-bio-blue/60">Transformaciones</p></div>
              <div><p class="text-2xl font-semibold tabular-nums text-bio-green md:text-3xl">100%</p><p class="mt-1 text-sm text-bio-blue/60">Online</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-b border-bio-grey bg-bio-white py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-bio-blue md:text-3xl">{METHOD.title}</h2>
          <p class="mt-2 text-lg text-bio-blue/80">{METHOD.tagline}</p>
          <ul class="mt-10 space-y-6">
            {METHOD.points.map((point) => (
              <li class="flex gap-4">
                <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-bio-green" aria-hidden="true" />
                <span class="break-words-safe text-base leading-relaxed text-bio-blue/90">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-12 rounded-2xl border border-bio-grey bg-bio-grey/30 p-8">
            <p class="font-serif text-2xl font-semibold text-bio-green md:text-3xl">{METHOD.stat}</p>
            <p class="mt-2 text-bio-blue/80">{METHOD.statLabel}</p>
            <a href="/example-2#planes" class="mt-6 inline-flex rounded-full bg-bio-green px-6 py-3 text-sm font-medium text-white hover:bg-bio-green/90">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-b border-bio-grey py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-bio-blue md:text-3xl">Planes</h2>
          <p class="mt-2 text-bio-blue/70">Cuestionario por Email tras el pago. Sólo Online.</p>
          <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col rounded-2xl border p-6 ${isRec ? 'border-bio-green bg-bio-green/5' : 'border-bio-grey bg-bio-white'}`}>
                  {isRec && <span class="mb-2 text-xs font-semibold uppercase tracking-wider text-bio-green">Recomendado</span>}
                  <h3 class="font-serif text-lg font-semibold text-bio-blue">{plan.name}</h3>
                  <p class="mt-2 text-2xl font-semibold text-bio-green">€{plan.price}<span class="text-sm font-normal text-bio-blue/60"> {plan.period}</span></p>
                  <p class="mt-3 flex-1 break-words-safe text-sm leading-relaxed text-bio-blue/80">{plan.description}</p>
                  <a href="/example-2#contacto" class="mt-6 min-h-[44px] rounded-full bg-bio-green py-3 text-center text-sm font-medium text-white transition hover:bg-bio-green/90">Comprar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-b border-bio-grey py-14 md:py-20">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-bio-blue">Dónde estamos</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 rounded-full border-2 border-bio-green px-5 py-2.5 text-sm font-medium text-bio-green hover:bg-bio-green/10">Ver en Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-b border-bio-grey py-14 md:py-20">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-bio-blue">Síguenos</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 rounded-full border-2 border-bio-green px-5 py-2.5 text-sm font-medium text-bio-green hover:bg-bio-green/10">@vfitness_nutricion</a>
          <div class="mt-8 grid grid-cols-3 gap-3 sm:grid-cols-4">
            {[1,2,3,4].map((i) => (
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden rounded-xl border border-bio-grey bg-bio-grey/50 transition hover:border-bio-green/50"><span class="flex h-full items-center justify-center text-sm text-bio-blue/40">Foto {i}</span></a>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-bio-blue">Contacto</h2>
          <form class="mt-8 max-w-md space-y-4" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="Nombre" class="w-full rounded-xl border border-bio-grey bg-bio-white px-4 py-3 text-bio-blue placeholder:text-bio-blue/40 focus:border-bio-green focus:outline-none" />
            <input type="email" name="email" placeholder="Email" class="w-full rounded-xl border border-bio-grey bg-bio-white px-4 py-3 text-bio-blue placeholder:text-bio-blue/40 focus:border-bio-green focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="Mensaje" class="w-full rounded-xl border border-bio-grey bg-bio-white px-4 py-3 text-bio-blue placeholder:text-bio-blue/40 focus:border-bio-green focus:outline-none" />
            <button type="submit" class="w-full rounded-full bg-bio-green py-3.5 text-sm font-medium text-white hover:bg-bio-green/90">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-bio-grey py-6">
      <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-2 px-4 text-sm text-bio-blue/60 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-bio-green">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-bio-green">Instagram</a> · <a href="/" class="hover:text-bio-green">Ejemplos</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => { mobileNav.classList.toggle('hidden'); menuBtn.setAttribute('aria-expanded', mobileNav.classList.contains('hidden') ? 'false' : 'true'); menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !mobileNav.classList.contains('hidden')); menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', mobileNav.classList.contains('hidden')); });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
  </script>
</Layout>
