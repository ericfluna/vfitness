---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
import heroLoop from '../assets/hero-loop.mp4';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Wellness Zen · Equilibrio Vital" description="Método VFitness. Nutrición integral y bienestar. Planes online.">
  <div class="min-h-screen bg-zen-cream font-zen text-zen-earth antialiased">
    <header class="sticky top-0 z-50 border-b border-zen-beige bg-zen-cream/95 backdrop-blur transition-all" id="main-header">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-4 md:px-8">
        <a href="/example-4" class="text-xl font-semibold text-zen-earth">VFitness</a>
        <nav class="hidden gap-8 text-sm text-zen-earth/80 md:flex">
          <a href="/example-4#metodo" class="hover:text-zen-olive">Método</a>
          <a href="/example-4#planes" class="hover:text-zen-olive">Planes</a>
          <a href="/example-4#ubicacion" class="hover:text-zen-olive">Ubicación</a>
          <a href="/example-4#contacto" class="hover:text-zen-olive">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/example-4#planes" class="rounded-full bg-zen-olive px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-zen-olive/90 md:inline-flex">Empezar</a>
          <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-zen-earth/30 text-zen-earth md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open">☰</span>
            <span class="menu-icon-close hidden">✕</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t border-zen-beige bg-zen-cream px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-3 text-sm">
          <a href="/example-4#metodo" class="py-2.5 text-zen-earth/80 hover:text-zen-olive">Método</a>
          <a href="/example-4#planes" class="py-2.5 text-zen-earth/80 hover:text-zen-olive">Planes</a>
          <a href="/example-4#ubicacion" class="py-2.5 text-zen-earth/80 hover:text-zen-olive">Ubicación</a>
          <a href="/example-4#contacto" class="py-2.5 text-zen-earth/80 hover:text-zen-olive">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[100vh] overflow-hidden" id="hero">
        <div class="absolute inset-0 bg-zen-cream" />
        <div class="absolute -right-32 -top-32 h-96 w-96 rounded-full bg-zen-olive/10 blur-3xl" aria-hidden="true" />
        <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-zen-beige/80 blur-2xl" aria-hidden="true" />
        <div class="relative z-10 flex min-h-[100vh] flex-col justify-center gap-8 px-4 py-24 md:flex-row md:items-center md:gap-12 md:px-8">
          <div class="mx-auto w-full max-w-2xl md:mx-0">
            <p class="text-sm font-semibold uppercase tracking-widest text-zen-olive">Bienestar integral</p>
            <h1 class="mt-6 font-zen text-4xl font-bold leading-tight text-zen-earth sm:text-5xl md:text-6xl">
              Tu cuerpo en equilibrio.<br />
              <span class="text-zen-olive">Sin obsesiones.</span>
            </h1>
            <p class="mt-8 text-base leading-relaxed text-zen-earth/80">
              Método simple y muy efectivo: metabolismo basal, macronutrientes y plan de entrenamiento. Más de 7.000 cambios. Sostenible.
            </p>
            <a href="/example-4#planes" class="mt-10 inline-flex rounded-full bg-zen-olive px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-zen-olive/90">Descubrir planes</a>
            <div class="mt-12 flex flex-wrap gap-12 border-t border-zen-beige pt-8 md:mt-20 md:pt-10">
              <div><p class="text-3xl font-bold text-zen-olive md:text-4xl">7.000+</p><p class="mt-1 text-sm text-zen-earth/60">Transformaciones</p></div>
              <div><p class="text-3xl font-bold text-zen-olive md:text-4xl">100%</p><p class="mt-1 text-sm text-zen-earth/60">Online</p></div>
            </div>
          </div>
          <div class="mx-auto w-full max-w-md shrink-0 md:mx-0">
            <div class="overflow-hidden rounded-3xl border-2 border-zen-beige bg-zen-beige/30 shadow-xl">
              <div class="aspect-video w-full">
                <video class="h-full w-full object-cover" autoplay loop muted playsinline aria-hidden="true" src={typeof heroLoop === 'string' ? heroLoop : heroLoop.src} />
              </div>
              <p class="px-4 py-3 text-center text-sm font-medium text-zen-earth/80">Tu transformación, paso a paso</p>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-t border-zen-beige bg-zen-cream py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-zen text-2xl font-bold text-zen-earth md:text-3xl">{METHOD.title}</h2>
          <p class="mt-2 text-lg text-zen-earth/80">{METHOD.tagline}</p>
          <ul class="mt-10 space-y-6">
            {METHOD.points.map((point) => (
              <li class="flex gap-4">
                <span class="mt-1.5 h-3 w-3 shrink-0 rounded-full bg-zen-olive/70" aria-hidden="true" />
                <span class="break-words-safe text-base leading-relaxed text-zen-earth/90">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-12 rounded-3xl bg-zen-beige/50 p-8">
            <p class="text-3xl font-bold text-zen-olive md:text-4xl">{METHOD.stat}</p>
            <p class="mt-2 text-zen-earth/80">{METHOD.statLabel}</p>
            <a href="/example-4#planes" class="mt-6 inline-flex rounded-full bg-zen-olive px-6 py-3 text-sm font-semibold text-white hover:bg-zen-olive/90">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-t border-zen-beige py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-zen text-2xl font-bold text-zen-earth md:text-3xl">Planes</h2>
          <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col rounded-3xl border-2 p-6 ${isRec ? 'border-zen-olive bg-zen-olive/10' : 'border-zen-beige bg-white'}`}>
                  {isRec && <span class="mb-2 text-xs font-semibold uppercase tracking-wider text-zen-olive">Recomendado</span>}
                  <h3 class="font-zen text-lg font-bold text-zen-earth">{plan.name}</h3>
                  <p class="mt-2 text-2xl font-bold text-zen-olive">€{plan.price}<span class="text-sm font-normal text-zen-earth/60"> {plan.period}</span></p>
                  <p class="mt-3 flex-1 break-words-safe text-sm leading-relaxed text-zen-earth/80">{plan.description}</p>
                  <a href="/example-4#contacto" class="mt-6 min-h-[44px] rounded-full bg-zen-olive py-3 text-center text-sm font-semibold text-white hover:bg-zen-olive/90">Comprar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-t border-zen-beige py-14 md:py-20">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-zen text-2xl font-bold text-zen-earth">Dónde estamos</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex rounded-full border-2 border-zen-olive px-5 py-2.5 text-sm font-semibold text-zen-olive hover:bg-zen-olive/10">Ver en Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-t border-zen-beige py-14 md:py-20">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-zen text-2xl font-bold text-zen-earth">Síguenos</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex rounded-full border-2 border-zen-olive px-5 py-2.5 text-sm font-semibold text-zen-olive hover:bg-zen-olive/10">@vfitness_nutricion</a>
          <div class="mt-8 grid grid-cols-3 gap-3 sm:grid-cols-4">
            {[1,2,3,4].map((i) => (
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden rounded-2xl border-2 border-zen-beige bg-white transition hover:border-zen-olive/50"><span class="flex h-full items-center justify-center text-sm text-zen-earth/40">Foto {i}</span></a>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <h2 class="font-zen text-2xl font-bold text-zen-earth">Contacto</h2>
          <form class="mt-8 max-w-md space-y-4" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="Nombre" class="w-full rounded-2xl border-2 border-zen-beige bg-white px-4 py-3.5 text-zen-earth placeholder:text-zen-earth/40 focus:border-zen-olive focus:outline-none" />
            <input type="email" name="email" placeholder="Email" class="w-full rounded-2xl border-2 border-zen-beige bg-white px-4 py-3.5 text-zen-earth placeholder:text-zen-earth/40 focus:border-zen-olive focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="Mensaje" class="w-full rounded-2xl border-2 border-zen-beige bg-white px-4 py-3.5 text-zen-earth placeholder:text-zen-earth/40 focus:border-zen-olive focus:outline-none" />
            <button type="submit" class="w-full rounded-full bg-zen-olive py-3.5 text-sm font-semibold text-white hover:bg-zen-olive/90">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-zen-beige py-6">
      <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-2 px-4 text-sm text-zen-earth/60 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-zen-olive">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-zen-olive">Instagram</a> · <a href="/" class="hover:text-zen-olive">Ejemplos</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => { mobileNav.classList.toggle('hidden'); menuBtn.setAttribute('aria-expanded', mobileNav.classList.contains('hidden') ? 'false' : 'true'); menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !mobileNav.classList.contains('hidden')); menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', mobileNav.classList.contains('hidden')); });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
  </script>
</Layout>
