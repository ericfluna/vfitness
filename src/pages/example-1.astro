---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Cyber-Athlete · Alto Rendimiento" description="Método VFitness. Tecnología y rendimiento. Dietas y entrenos personalizados online.">
  <div class="min-h-screen bg-cyber-black font-mono text-cyber-cyan antialiased">
    <header class="sticky top-0 z-50 border-b border-cyber-metal/50 bg-cyber-black/90 backdrop-blur transition-all" id="main-header">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-3 md:px-8">
        <a href="/example-1" class="text-sm font-bold tracking-widest text-cyber-cyan">VFITNESS::v2</a>
        <nav class="hidden gap-6 text-xs uppercase tracking-wider text-cyber-cyan/80 md:flex">
          <a href="/example-1#metodo">Método</a>
          <a href="/example-1#planes">Planes</a>
          <a href="/example-1#ubicacion">Ubicación</a>
          <a href="/example-1#contacto">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/example-1#planes" class="rounded border border-cyber-cyan px-3 py-2 text-xs font-medium text-cyber-cyan transition hover:bg-cyber-cyan/10 md:inline-flex">INICIAR</a>
          <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center border border-cyber-metal text-cyber-cyan md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open">≡</span>
            <span class="menu-icon-close hidden">×</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t border-cyber-metal bg-cyber-black px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-2 text-xs uppercase tracking-wider">
          <a href="/example-1#metodo" class="py-2 text-cyber-cyan/80 hover:text-cyber-cyan">Método</a>
          <a href="/example-1#planes" class="py-2 text-cyber-cyan/80 hover:text-cyber-cyan">Planes</a>
          <a href="/example-1#ubicacion" class="py-2 text-cyber-cyan/80 hover:text-cyber-cyan">Ubicación</a>
          <a href="/example-1#contacto" class="py-2 text-cyber-cyan/80 hover:text-cyber-cyan">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[100vh] overflow-hidden border-b border-cyber-metal/30" id="hero">
        <div class="absolute inset-0 bg-cyber-black" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent_0%,rgba(0,245,255,0.03)_50%,transparent_100%)] bg-[length_100%_4px]" style="animation: scan 4s linear infinite;" aria-hidden="true" />
        <div class="absolute left-0 top-0 h-full w-px bg-cyber-cyan/20" aria-hidden="true" />
        <div class="absolute right-0 top-0 h-full w-px bg-cyber-cyan/20" aria-hidden="true" />
        <div class="relative z-10 flex min-h-[100vh] flex-col justify-center px-4 py-20 md:px-8">
          <div class="mx-auto w-full max-w-4xl">
            <p class="text-[10px] uppercase tracking-[0.4em] text-cyber-violet">// SISTEMA_OPTIMIZACION</p>
            <h1 class="mt-4 font-mono text-3xl font-bold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl">
              <span class="block text-cyber-cyan">RENDIMIENTO</span>
              <span class="block text-white">OPTIMIZADO</span>
            </h1>
            <p class="mt-6 max-w-lg text-sm leading-relaxed text-cyber-cyan/80">
              Método basado en datos. Calorías, macros y plan de entrenamiento específico. Más de 7.000 transformaciones.
            </p>
            <a href="/example-1#planes" class="mt-8 inline-block border-2 border-cyber-cyan px-6 py-3 text-xs font-bold uppercase tracking-widest text-cyber-cyan transition hover:bg-cyber-cyan/10">ACCESO</a>
            <div class="mt-16 flex flex-wrap gap-10 border-t border-cyber-metal/50 pt-8">
              <div><p class="text-2xl font-bold tabular-nums text-cyber-cyan md:text-3xl">7000+</p><p class="mt-0.5 text-[10px] uppercase text-cyber-cyan/60">CAMBIOS</p></div>
              <div><p class="text-2xl font-bold tabular-nums text-cyber-cyan md:text-3xl">100%</p><p class="mt-0.5 text-[10px] uppercase text-cyber-cyan/60">ONLINE</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-b border-cyber-metal/30 bg-cyber-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-cyber-cyan md:text-xl">{METHOD.title}</h2>
          <p class="mt-2 text-sm text-cyber-cyan/80">{METHOD.tagline}</p>
          <ul class="mt-8 space-y-4">
            {METHOD.points.map((point) => (
              <li class="flex gap-3 text-sm text-white/90">
                <span class="text-cyber-cyan">›</span>
                <span class="break-words-safe">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-10 border border-cyber-cyan/30 bg-cyber-grey/50 p-6">
            <p class="text-2xl font-bold text-cyber-cyan md:text-3xl">{METHOD.stat}</p>
            <p class="mt-1 text-sm text-cyber-cyan/80">{METHOD.statLabel}</p>
            <a href="/example-1#planes" class="mt-4 inline-block border border-cyber-cyan px-4 py-2 text-xs font-bold uppercase text-cyber-cyan">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-b border-cyber-metal/30 bg-cyber-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-cyber-cyan md:text-xl">Planes</h2>
          <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col border p-4 sm:p-5 ${isRec ? 'border-cyber-cyan bg-cyber-cyan/5' : 'border-cyber-metal bg-cyber-grey/30'}`}>
                  {isRec && <span class="mb-2 text-[10px] font-bold uppercase text-cyber-cyan">RECOMENDADO</span>}
                  <h3 class="font-mono text-sm font-bold text-white">{plan.name}</h3>
                  <p class="mt-2 font-mono text-xl font-bold text-cyber-cyan">€{plan.price}<span class="ml-1 text-xs font-normal text-cyber-cyan/70">{plan.period}</span></p>
                  <p class="mt-2 flex-1 break-words-safe text-xs leading-relaxed text-white/70">{plan.description}</p>
                  <a href="/example-1#contacto" class="mt-4 w-full border border-cyber-cyan py-2.5 text-center text-xs font-bold uppercase text-cyber-cyan transition hover:bg-cyber-cyan/10">Comprar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-b border-cyber-metal/30 py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-cyber-cyan">Ubicación</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-cyber-cyan px-4 py-2 text-sm text-cyber-cyan hover:bg-cyber-cyan/10">Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-b border-cyber-metal/30 py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-cyber-cyan">Instagram</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-cyber-cyan px-4 py-2 text-sm text-cyber-cyan hover:bg-cyber-cyan/10">@vfitness_nutricion</a>
          <div class="mt-8 grid grid-cols-3 gap-2 sm:grid-cols-4">
            {[1,2,3,4].map((i) => (
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square border border-cyber-metal bg-cyber-grey/50 transition hover:border-cyber-cyan/50"><span class="flex h-full items-center justify-center text-[10px] text-cyber-cyan/40">[{i}]</span></a>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-cyber-cyan">Contacto</h2>
          <form class="mt-6 max-w-md space-y-3" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="NOMBRE" class="w-full border border-cyber-metal bg-cyber-grey/50 px-3 py-2.5 text-sm text-white placeholder:text-cyber-cyan/40 focus:border-cyber-cyan focus:outline-none" />
            <input type="email" name="email" placeholder="EMAIL" class="w-full border border-cyber-metal bg-cyber-grey/50 px-3 py-2.5 text-sm text-white placeholder:text-cyber-cyan/40 focus:border-cyber-cyan focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="MENSAJE" class="w-full border border-cyber-metal bg-cyber-grey/50 px-3 py-2.5 text-sm text-white placeholder:text-cyber-cyan/40 focus:border-cyber-cyan focus:outline-none" />
            <button type="submit" class="w-full border-2 border-cyber-cyan py-3 text-xs font-bold uppercase text-cyber-cyan hover:bg-cyber-cyan/10">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-cyber-metal/30 py-4">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 text-[10px] text-cyber-cyan/60 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-cyber-cyan">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-cyber-cyan">Instagram</a> · <a href="/" class="hover:text-cyber-cyan">Ejemplos</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => {
        const open = mobileNav.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!open));
        menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !open);
        menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', open);
      });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
  </script>
  <style is:global>
    @keyframes scan {
      0%, 100% { background-position: 0 -100%; }
      50% { background-position: 0 200%; }
    }
  </style>
</Layout>
