---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Luxury · Exclusividad" description="Método VFitness. Asesoría premium. Planes personalizados online.">
  <div class="min-h-screen bg-luxury-navy font-luxury text-luxury-champagne antialiased">
    <header class="sticky top-0 z-50 border-b border-white/5 bg-luxury-navy/90 backdrop-blur transition-all" id="main-header">
      <div class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-4 px-4 py-5 md:px-8">
        <a href="/example-5" class="font-luxury text-xl font-semibold tracking-wide text-luxury-champagne">VFitness</a>
        <nav class="hidden gap-10 text-sm tracking-wide text-luxury-champagne/70 md:flex">
          <a href="/example-5#metodo" class="hover:text-luxury-gold">Método</a>
          <a href="/example-5#planes" class="hover:text-luxury-gold">Planes</a>
          <a href="/example-5#ubicacion" class="hover:text-luxury-gold">Ubicación</a>
          <a href="/example-5#contacto" class="hover:text-luxury-gold">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/example-5#planes" class="border border-luxury-gold/50 px-5 py-2.5 text-sm tracking-wide text-luxury-gold transition hover:bg-luxury-gold/10 md:inline-flex">Solicitar</a>
          <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center border border-luxury-champagne/20 text-luxury-champagne md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open">☰</span>
            <span class="menu-icon-close hidden">✕</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t border-white/5 bg-luxury-navy px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-3 text-sm tracking-wide">
          <a href="/example-5#metodo" class="py-2.5 text-luxury-champagne/70 hover:text-luxury-gold">Método</a>
          <a href="/example-5#planes" class="py-2.5 text-luxury-champagne/70 hover:text-luxury-gold">Planes</a>
          <a href="/example-5#ubicacion" class="py-2.5 text-luxury-champagne/70 hover:text-luxury-gold">Ubicación</a>
          <a href="/example-5#contacto" class="py-2.5 text-luxury-champagne/70 hover:text-luxury-gold">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[100vh] overflow-hidden" id="hero">
        <div class="absolute inset-0 bg-luxury-navy" />
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-luxury-gold/30 to-transparent" aria-hidden="true" />
        <div class="relative z-10 flex min-h-[100vh] flex-col justify-center px-4 py-24 md:px-8">
          <div class="mx-auto w-full max-w-2xl text-center">
            <h1 class="font-luxury text-4xl font-semibold leading-tight tracking-wide text-luxury-champagne sm:text-5xl md:text-6xl">
              Resultados que<br />
              <span class="text-luxury-gold">se mantienen.</span>
            </h1>
            <p class="mt-8 text-base leading-relaxed text-luxury-champagne/70">
              Método simple y muy efectivo. Más de 7.000 cambios. Asesoría personalizada y discreta.
            </p>
            <a href="/example-5#planes" class="mt-10 inline-block border border-luxury-gold/50 px-8 py-3.5 text-sm tracking-wide text-luxury-gold transition hover:bg-luxury-gold/10">Ver planes</a>
            <div class="mt-20 flex flex-wrap justify-center gap-16 border-t border-white/5 pt-10">
              <div><p class="font-luxury text-3xl font-semibold text-luxury-gold md:text-4xl">7.000+</p><p class="mt-1 text-xs tracking-widest text-luxury-champagne/50">CAMBIOS</p></div>
              <div><p class="font-luxury text-3xl font-semibold text-luxury-gold md:text-4xl">100%</p><p class="mt-1 text-xs tracking-widest text-luxury-champagne/50">ONLINE</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-t border-white/5 py-20 md:py-28">
        <div class="mx-auto max-w-3xl px-4 md:px-8">
          <h2 class="font-luxury text-3xl font-semibold tracking-wide text-luxury-champagne md:text-4xl">{METHOD.title}</h2>
          <p class="mt-4 text-lg italic text-luxury-champagne/70">{METHOD.tagline}</p>
          <ul class="mt-12 space-y-8">
            {METHOD.points.map((point) => (
              <li class="border-l-2 border-luxury-gold/30 pl-6">
                <span class="break-words-safe text-luxury-champagne/90">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-16 border border-luxury-gold/20 p-8">
            <p class="font-luxury text-3xl font-semibold text-luxury-gold md:text-4xl">{METHOD.stat}</p>
            <p class="mt-2 text-luxury-champagne/70">{METHOD.statLabel}</p>
            <a href="/example-5#planes" class="mt-6 inline-block border border-luxury-gold/50 px-6 py-2.5 text-sm tracking-wide text-luxury-gold hover:bg-luxury-gold/10">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-t border-white/5 py-20 md:py-28">
        <div class="mx-auto max-w-4xl px-4 md:px-8">
          <h2 class="font-luxury text-3xl font-semibold tracking-wide text-luxury-champagne md:text-4xl">Planes</h2>
          <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col border p-6 ${isRec ? 'border-luxury-gold/50 bg-luxury-gold/5' : 'border-white/10 bg-white/5'}`}>
                  {isRec && <span class="mb-2 text-xs tracking-widest text-luxury-gold">Recomendado</span>}
                  <h3 class="font-luxury text-xl font-semibold text-luxury-champagne">{plan.name}</h3>
                  <p class="mt-3 font-luxury text-2xl font-semibold text-luxury-gold">€{plan.price}<span class="text-sm font-normal text-luxury-champagne/50"> {plan.period}</span></p>
                  <p class="mt-4 flex-1 break-words-safe text-sm leading-relaxed text-luxury-champagne/70">{plan.description}</p>
                  <a href="/example-5#contacto" class="mt-6 min-h-[44px] border border-luxury-gold/50 py-3 text-center text-sm tracking-wide text-luxury-gold transition hover:bg-luxury-gold/10">Comprar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-t border-white/5 py-14 md:py-20">
        <div class="mx-auto max-w-4xl px-4 md:px-8">
          <h2 class="font-luxury text-3xl font-semibold text-luxury-champagne">Ubicación</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-luxury-gold/50 px-5 py-2.5 text-sm tracking-wide text-luxury-gold hover:bg-luxury-gold/10">Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-t border-white/5 py-14 md:py-20">
        <div class="mx-auto max-w-4xl px-4 md:px-8">
          <h2 class="font-luxury text-3xl font-semibold text-luxury-champagne">Instagram</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-luxury-gold/50 px-5 py-2.5 text-sm tracking-wide text-luxury-gold hover:bg-luxury-gold/10">@vfitness_nutricion</a>
          <div class="mt-8 grid grid-cols-3 gap-3 sm:grid-cols-4">
            {[1,2,3,4].map((i) => (
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square border border-white/10 transition hover:border-luxury-gold/30"><span class="flex h-full items-center justify-center text-xs text-luxury-champagne/30">Foto {i}</span></a>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="py-20 md:py-28">
        <div class="mx-auto max-w-4xl px-4 md:px-8">
          <h2 class="font-luxury text-3xl font-semibold text-luxury-champagne">Contacto</h2>
          <form class="mt-10 max-w-md space-y-4" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="Nombre" class="w-full border border-white/10 bg-white/5 px-4 py-3.5 text-luxury-champagne placeholder:text-luxury-champagne/40 focus:border-luxury-gold/50 focus:outline-none" />
            <input type="email" name="email" placeholder="Email" class="w-full border border-white/10 bg-white/5 px-4 py-3.5 text-luxury-champagne placeholder:text-luxury-champagne/40 focus:border-luxury-gold/50 focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="Mensaje" class="w-full border border-white/10 bg-white/5 px-4 py-3.5 text-luxury-champagne placeholder:text-luxury-champagne/40 focus:border-luxury-gold/50 focus:outline-none" />
            <button type="submit" class="w-full border border-luxury-gold/50 py-3.5 text-sm tracking-wide text-luxury-gold hover:bg-luxury-gold/10">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/5 py-8">
      <div class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-2 px-4 text-xs tracking-widest text-luxury-champagne/50 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-luxury-gold">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-luxury-gold">Instagram</a> · <a href="/" class="hover:text-luxury-gold">Ejemplos</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => { mobileNav.classList.toggle('hidden'); menuBtn.setAttribute('aria-expanded', mobileNav.classList.contains('hidden') ? 'false' : 'true'); menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !mobileNav.classList.contains('hidden')); menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', mobileNav.classList.contains('hidden')); });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
  </script>
</Layout>
