---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
import heroLoop from '../assets/hero-loop.mp4';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Preparación · Nivel Competición" description="Método VFitness. Preparación profesional. Dietas y entrenos para atletas.">
  <div class="min-h-screen bg-dash-dark font-sans text-dash-white antialiased">
    <header class="sticky top-0 z-50 border-b border-dash-gold/40 bg-dash-dark/95 backdrop-blur" id="main-header">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-4 md:px-8">
        <div class="flex items-center gap-3">
          <a href="/example-8" class="font-serif text-xl font-semibold tracking-wide text-dash-gold">VFitness</a>
          <span class="rounded border border-dash-gold/50 px-2 py-0.5 text-[10px] uppercase tracking-widest text-dash-gold/80">Preparación</span>
        </div>
        <nav class="hidden gap-8 text-sm tracking-wide text-dash-white/80 md:flex">
          <a href="/example-8#metodo" class="hover:text-dash-gold">Método</a>
          <a href="/example-8#planes" class="hover:text-dash-gold">Planes</a>
          <a href="/example-8#ubicacion" class="hover:text-dash-gold">Ubicación</a>
          <a href="/example-8#contacto" class="hover:text-dash-gold">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/example-8#planes" class="border border-dash-gold px-5 py-2.5 text-sm font-medium tracking-wide text-dash-gold transition hover:bg-dash-gold/10 md:inline-flex">Consultar planes</a>
          <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center border border-dash-gold/50 text-dash-gold md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open">≡</span>
            <span class="menu-icon-close hidden">×</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t border-dash-gold/30 bg-dash-dark px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-2 text-sm tracking-wide">
          <a href="/example-8#metodo" class="py-3 text-dash-white/80 hover:text-dash-gold">Método</a>
          <a href="/example-8#planes" class="py-3 text-dash-white/80 hover:text-dash-gold">Planes</a>
          <a href="/example-8#ubicacion" class="py-3 text-dash-white/80 hover:text-dash-gold">Ubicación</a>
          <a href="/example-8#contacto" class="py-3 text-dash-white/80 hover:text-dash-gold">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[100vh] overflow-hidden border-b border-dash-gold/30" id="hero">
        <div class="absolute inset-0 z-0">
          <video class="h-full w-full object-cover" autoplay loop muted playsinline aria-hidden="true" src={typeof heroLoop === 'string' ? heroLoop : heroLoop.src} />
        </div>
        <div class="absolute inset-0 z-[1] bg-dash-dark/70" aria-hidden="true" />
        <div class="absolute bottom-0 left-0 right-0 z-[1] h-1/3 bg-gradient-to-t from-dash-dark to-transparent" aria-hidden="true" />
        <div class="relative z-[2] flex min-h-[100vh] flex-col justify-end px-4 pb-24 pt-32 md:px-8 md:pb-32">
          <div class="mx-auto w-full max-w-3xl">
            <p class="text-xs font-medium uppercase tracking-[0.3em] text-dash-gold">Preparación profesional</p>
            <h1 class="mt-4 font-serif text-4xl font-semibold leading-tight tracking-wide text-dash-white sm:text-5xl md:text-6xl">
              Disciplina.<br />
              <span class="text-dash-gold">Resultados.</span>
            </h1>
            <p class="mt-6 max-w-lg text-sm leading-relaxed text-dash-white/80">
              Método contrastado. Más de 7.000 transformaciones. Dieta y entreno personalizados para llevar tu físico al siguiente nivel.
            </p>
            <a href="/example-8#planes" class="mt-8 inline-block border border-dash-gold px-8 py-3.5 text-sm font-medium tracking-wide text-dash-gold transition hover:bg-dash-gold/10">Ver planes</a>
            <div class="mt-16 flex flex-wrap gap-12 border-t border-dash-gold/30 pt-8">
              <div><p class="font-serif text-3xl font-semibold text-dash-gold md:text-4xl">7.000+</p><p class="mt-1 text-xs uppercase tracking-widest text-dash-white/50">Transformaciones</p></div>
              <div><p class="font-serif text-3xl font-semibold text-dash-gold md:text-4xl">100%</p><p class="mt-1 text-xs uppercase tracking-widest text-dash-white/50">Online</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-b border-dash-gold/30 bg-dash-dark py-16 md:py-24">
        <div class="mx-auto max-w-3xl px-4 md:px-8">
          <p class="text-xs font-medium uppercase tracking-[0.25em] text-dash-gold">Metodología</p>
          <h2 class="mt-2 font-serif text-3xl font-semibold tracking-wide text-dash-white md:text-4xl">{METHOD.title}</h2>
          <p class="mt-4 text-dash-white/80">{METHOD.tagline}</p>
          <ul class="mt-10 space-y-6">
            {METHOD.points.map((point) => (
              <li class="border-l-2 border-dash-gold/50 pl-6">
                <span class="break-words-safe text-dash-white/90">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-14 border border-dash-gold/30 bg-dash-base/30 py-8 pl-8 pr-8">
            <p class="font-serif text-2xl font-semibold text-dash-gold md:text-3xl">{METHOD.stat}</p>
            <p class="mt-2 text-sm text-dash-white/70">{METHOD.statLabel}</p>
            <a href="/example-8#planes" class="mt-6 inline-block border border-dash-gold px-6 py-2.5 text-sm font-medium text-dash-gold hover:bg-dash-gold/10">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-b border-dash-gold/30 bg-dash-base/20 py-16 md:py-24">
        <div class="mx-auto max-w-5xl px-4 md:px-8">
          <p class="text-xs font-medium uppercase tracking-[0.25em] text-dash-gold">Planes</p>
          <h2 class="mt-2 font-serif text-3xl font-semibold text-dash-white md:text-4xl">Elige tu preparación</h2>
          <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col border p-6 ${isRec ? 'border-dash-gold bg-dash-dark' : 'border-dash-gold/30 bg-dash-dark/50'}`}>
                  {isRec && <span class="mb-2 text-xs font-medium uppercase tracking-widest text-dash-gold">Recomendado</span>}
                  <h3 class="font-serif text-lg font-semibold text-dash-white">{plan.name}</h3>
                  <p class="mt-2 font-serif text-2xl font-semibold text-dash-gold">€{plan.price}<span class="ml-1 text-sm font-normal text-dash-white/60">{plan.period}</span></p>
                  <p class="mt-3 flex-1 break-words-safe text-sm leading-relaxed text-dash-white/70">{plan.description}</p>
                  <a href="/example-8#contacto" class="mt-6 w-full border border-dash-gold py-3 text-center text-sm font-medium text-dash-gold transition hover:bg-dash-gold/10">Solicitar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-b border-dash-gold/30 py-14 md:py-20">
        <div class="mx-auto max-w-3xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-dash-gold">Ubicación</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-dash-gold/50 px-5 py-2.5 text-sm text-dash-gold hover:bg-dash-gold/10">Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-b border-dash-gold/30 py-14 md:py-20">
        <div class="mx-auto max-w-3xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-dash-gold">Instagram</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-dash-gold/50 px-5 py-2.5 text-sm text-dash-gold hover:bg-dash-gold/10">@vfitness_nutricion</a>
        </div>
      </section>

      <section id="contacto" class="py-16 md:py-24">
        <div class="mx-auto max-w-3xl px-4 md:px-8">
          <h2 class="font-serif text-2xl font-semibold text-dash-gold">Contacto</h2>
          <form class="mt-8 max-w-sm space-y-4" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="Nombre" class="w-full border border-dash-gold/30 bg-dash-base/50 px-4 py-3 text-dash-white placeholder:text-dash-white/40 focus:border-dash-gold focus:outline-none" />
            <input type="email" name="email" placeholder="Email" class="w-full border border-dash-gold/30 bg-dash-base/50 px-4 py-3 text-dash-white placeholder:text-dash-white/40 focus:border-dash-gold focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="Mensaje" class="w-full border border-dash-gold/30 bg-dash-base/50 px-4 py-3 text-dash-white placeholder:text-dash-white/40 focus:border-dash-gold focus:outline-none" />
            <button type="submit" class="w-full border border-dash-gold py-3.5 text-sm font-medium text-dash-gold hover:bg-dash-gold/10">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-dash-gold/30 py-6">
      <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-2 px-4 text-xs text-dash-white/50 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-dash-gold">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-dash-gold">Instagram</a> · <a href="/" class="hover:text-dash-gold">Ejemplos</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => { mobileNav.classList.toggle('hidden'); menuBtn.setAttribute('aria-expanded', mobileNav.classList.contains('hidden') ? 'false' : 'true'); menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !mobileNav.classList.contains('hidden')); menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', mobileNav.classList.contains('hidden')); });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
  </script>
</Layout>
