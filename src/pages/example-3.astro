---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
import heroLoop from '../assets/hero-loop.mp4';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Brutalist · Fuerza y Esfuerzo" description="Método VFitness. Entrenamiento de fuerza y nutrición. Planes online.">
  <div class="min-h-screen bg-brutal-dark font-brutal text-white antialiased">
    <header class="sticky top-0 z-50 border-b-4 border-brutal-black bg-brutal-dark transition-all" id="main-header">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 md:px-8">
        <a href="/example-3" class="text-2xl tracking-tighter text-brutal-yellow md:text-3xl">VFITNESS</a>
        <nav class="hidden gap-8 text-lg tracking-tight text-white/90 md:flex">
          <a href="/example-3#metodo" class="hover:text-brutal-yellow">Método</a>
          <a href="/example-3#planes" class="hover:text-brutal-yellow">Planes</a>
          <a href="/example-3#ubicacion" class="hover:text-brutal-yellow">Ubicación</a>
          <a href="/example-3#contacto" class="hover:text-brutal-yellow">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/example-3#planes" class="bg-brutal-yellow px-6 py-3 text-lg font-normal tracking-tight text-brutal-black transition hover:bg-brutal-yellow/90 md:inline-flex">EMPEZAR</a>
          <button type="button" class="flex h-12 w-12 shrink-0 items-center justify-center border-4 border-brutal-yellow text-brutal-yellow md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open text-xl">≡</span>
            <span class="menu-icon-close hidden text-xl">×</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t-4 border-brutal-yellow bg-brutal-dark px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-2 text-xl tracking-tight">
          <a href="/example-3#metodo" class="py-3 text-white/90 hover:text-brutal-yellow">Método</a>
          <a href="/example-3#planes" class="py-3 text-white/90 hover:text-brutal-yellow">Planes</a>
          <a href="/example-3#ubicacion" class="py-3 text-white/90 hover:text-brutal-yellow">Ubicación</a>
          <a href="/example-3#contacto" class="py-3 text-white/90 hover:text-brutal-yellow">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[100vh] overflow-hidden border-b-4 border-brutal-black" id="hero">
        <div class="absolute inset-0 bg-brutal-dark" />
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(250,204,21,0.05)_0%,transparent_70%)]" aria-hidden="true" />
        <div class="absolute right-4 top-1/2 z-10 w-[min(320px,85vw)] -translate-y-1/2 border-4 border-brutal-yellow bg-brutal-black p-2 md:right-8 md:w-96">
          <div class="aspect-video w-full overflow-hidden">
            <video class="h-full w-full object-cover" autoplay loop muted playsinline aria-hidden="true" src={typeof heroLoop === 'string' ? heroLoop : heroLoop.src} />
          </div>
        </div>
        <div class="relative z-10 flex min-h-[100vh] flex-col justify-center px-4 py-20 md:px-8">
          <div class="mx-auto w-full max-w-2xl md:max-w-3xl">
            <h1 class="text-5xl leading-[0.95] tracking-tighter text-white sm:text-6xl md:text-7xl lg:text-8xl">
              NO<br />
              <span class="text-brutal-yellow">TE PARES.</span>
            </h1>
            <p class="mt-8 max-w-xl text-lg text-white/80">
              Método simple y muy efectivo. Calorías, macros y plan de entrenamiento. Más de 7.000 cambios. Sin tonterías.
            </p>
            <a href="/example-3#planes" class="mt-10 inline-block bg-brutal-yellow px-8 py-4 text-2xl tracking-tight text-brutal-black transition hover:bg-brutal-yellow/90">EMPEZAR</a>
            <div class="mt-20 flex flex-wrap gap-16 border-t-4 border-brutal-cement/30 pt-10">
              <div><p class="text-5xl tracking-tighter text-brutal-yellow md:text-6xl">7000+</p><p class="mt-1 text-sm uppercase tracking-widest text-white/50">CAMBIOS</p></div>
              <div><p class="text-5xl tracking-tighter text-brutal-yellow md:text-6xl">100%</p><p class="mt-1 text-sm uppercase tracking-widest text-white/50">ONLINE</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-b-4 border-brutal-black bg-brutal-dark py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="text-4xl tracking-tighter text-brutal-yellow md:text-5xl">{METHOD.title}</h2>
          <p class="mt-4 text-lg text-white/80">{METHOD.tagline}</p>
          <ul class="mt-10 space-y-6">
            {METHOD.points.map((point) => (
              <li class="flex gap-4 text-lg text-white/90">
                <span class="block h-1 w-8 shrink-0 bg-brutal-yellow self-center" aria-hidden="true" />
                <span class="break-words-safe">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-14 border-4 border-brutal-yellow bg-brutal-black p-8">
            <p class="text-4xl tracking-tighter text-brutal-yellow md:text-5xl">{METHOD.stat}</p>
            <p class="mt-2 text-white/80">{METHOD.statLabel}</p>
            <a href="/example-3#planes" class="mt-6 inline-block bg-brutal-yellow px-6 py-3 text-xl tracking-tight text-brutal-black">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-b-4 border-brutal-black py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="text-4xl tracking-tighter text-brutal-yellow md:text-5xl">Planes</h2>
          <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col border-4 p-6 shadow-brutal ${isRec ? 'border-brutal-yellow bg-brutal-yellow/10' : 'border-brutal-cement bg-brutal-dark'}`}>
                  {isRec && <span class="mb-2 text-sm tracking-widest text-brutal-yellow">RECOMENDADO</span>}
                  <h3 class="text-2xl tracking-tight text-white">{plan.name}</h3>
                  <p class="mt-3 text-3xl tracking-tight text-brutal-yellow">€{plan.price}<span class="text-base text-white/60"> {plan.period}</span></p>
                  <p class="mt-4 flex-1 break-words-safe text-white/80">{plan.description}</p>
                  <a href="/example-3#contacto" class="mt-6 w-full bg-brutal-yellow py-4 text-center text-xl tracking-tight text-brutal-black hover:bg-brutal-yellow/90">Comprar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-b-4 border-brutal-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="text-4xl tracking-tighter text-brutal-yellow">Ubicación</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-6 inline-block border-4 border-brutal-yellow px-6 py-3 text-lg text-brutal-yellow hover:bg-brutal-yellow/10">Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-b-4 border-brutal-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="text-4xl tracking-tighter text-brutal-yellow">Instagram</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-6 inline-block border-4 border-brutal-yellow px-6 py-3 text-lg text-brutal-yellow hover:bg-brutal-yellow/10">@vfitness_nutricion</a>
          <div class="mt-8 grid grid-cols-3 gap-3 sm:grid-cols-4">
            {[1,2,3,4].map((i) => (
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square border-4 border-brutal-cement bg-brutal-black transition hover:border-brutal-yellow"><span class="flex h-full items-center justify-center text-white/30">[{i}]</span></a>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="text-4xl tracking-tighter text-brutal-yellow">Contacto</h2>
          <form class="mt-8 max-w-md space-y-4" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="Nombre" class="w-full border-4 border-brutal-cement bg-brutal-black px-4 py-4 text-white placeholder:text-white/40 focus:border-brutal-yellow focus:outline-none" />
            <input type="email" name="email" placeholder="Email" class="w-full border-4 border-brutal-cement bg-brutal-black px-4 py-4 text-white placeholder:text-white/40 focus:border-brutal-yellow focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="Mensaje" class="w-full border-4 border-brutal-cement bg-brutal-black px-4 py-4 text-white placeholder:text-white/40 focus:border-brutal-yellow focus:outline-none" />
            <button type="submit" class="w-full bg-brutal-yellow py-4 text-xl tracking-tight text-brutal-black hover:bg-brutal-yellow/90">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t-4 border-brutal-black py-6">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 text-white/60 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-brutal-yellow">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-brutal-yellow">Instagram</a> · <a href="/" class="hover:text-brutal-yellow">Ejemplos</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => { mobileNav.classList.toggle('hidden'); menuBtn.setAttribute('aria-expanded', mobileNav.classList.contains('hidden') ? 'false' : 'true'); menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !mobileNav.classList.contains('hidden')); menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', mobileNav.classList.contains('hidden')); });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
  </script>
</Layout>
