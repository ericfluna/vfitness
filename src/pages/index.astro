---
import Layout from '../layouts/Layout.astro';

const examples = [
  {
    slug: 'example-1',
    title: 'Ejemplo 1',
    subtitle: 'Base (colores dashboard)',
    description: 'Paleta del dashboard (oscuro, oro). Tipografía mono, línea de escáner en el hero, vídeo a pantalla completa. Es la base de la que salen el brutalist, pro IFBB y minimal.',
    cta: 'Ver ejemplo 1',
  },
  {
    slug: 'example-2',
    title: 'Ejemplo 2',
    subtitle: 'Brutalist',
    description: 'Misma paleta, más brutal: Bebas Neue, bordes gruesos, titulares enormes, vídeo de fondo. Sin concesiones.',
    cta: 'Ver ejemplo 2',
  },
  {
    slug: 'example-3',
    title: 'Ejemplo 3',
    subtitle: 'Pro IFBB',
    description: 'Misma paleta, tono competición: serif, badge «Preparación», layout serio. Para atletas y nivel élite.',
    cta: 'Ver ejemplo 3',
  },
  {
    slug: 'example-4',
    title: 'Ejemplo 4',
    subtitle: 'Minimalista',
    description: 'Misma paleta, máximo minimalismo: sin vídeo, una columna, mucho aire, solo lo esencial.',
    cta: 'Ver ejemplo 4',
  },
];
---

<Layout
  title="VFitness · Webs de prueba para el entrenador"
  description="Seis ejemplos de landing para VFitness. Elige la dirección visual que más encaje con tu marca."
>
  <div class="min-h-screen bg-black text-vfit-white">
    <header class="border-b border-neutral-800 bg-black/90 backdrop-blur">
      <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3 md:px-6">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold tracking-[0.2em] text-vfit-gold">V-FITNESS</span>
          <span class="rounded bg-neutral-800 px-2 py-0.5 text-[10px] uppercase text-neutral-400">Webs de prueba</span>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-4xl px-4 py-6 md:py-8">
      <section class="mb-6 md:mb-8">
        <h1 class="text-xl font-semibold tracking-tight text-vfit-white md:text-2xl">
          Ideas para tu web
        </h1>
        <p class="mt-2 max-w-2xl text-sm leading-relaxed text-neutral-400">
          Hola. Aquí tienes <strong class="text-vfit-gold">varios ejemplos</strong> (base, brutalist, pro IFBB, minimal) con los mismos colores del dashboard. Entra en cada uno, mira qué te mola (colores, tono, estructura) y cuando tengas claro qué te encaja, lo vemos y afinamos.
        </p>
      </section>

      <a
        href="/dashboard"
        class="mb-8 flex items-center justify-between gap-4 rounded-xl border-2 border-vfit-gold/50 bg-vfit-gold/10 px-5 py-4 transition hover:border-vfit-gold hover:bg-vfit-gold/15"
      >
        <div>
          <p class="font-semibold text-vfit-gold">Dashboard</p>
          <p class="mt-0.5 text-xs text-neutral-400">Panel de usuarios con datos de prueba</p>
        </div>
        <span class="text-vfit-gold">→</span>
      </a>

      <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" aria-label="Ejemplos de web VFitness">
        {examples.map((ex) => (
          <a
            href={`/${ex.slug}`}
            class="group flex flex-col rounded-xl border border-neutral-800 bg-neutral-950/80 p-4 transition hover:border-vfit-gold/50 hover:bg-neutral-900/80"
          >
            <div class="mb-1 flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-wider text-vfit-gold">{ex.title}</span>
              <span class="text-[10px] uppercase text-neutral-500">{ex.subtitle}</span>
            </div>
            <h2 class="text-base font-semibold text-vfit-white group-hover:text-vfit-gold/90">{ex.subtitle}</h2>
            <p class="mt-1.5 flex-1 text-xs text-neutral-400 leading-snug">
              {ex.description}
            </p>
            <span class="mt-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-vfit-gold group-hover:gap-3 transition-[gap]">
              {ex.cta}
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </section>

      <p class="mt-6 text-center text-xs text-neutral-500">
        En cada ejemplo puedes volver aquí con «Ver todos los ejemplos» en el pie.
      </p>
    </div>

    <footer class="mt-10 border-t border-neutral-900 py-4">
      <div class="mx-auto max-w-4xl px-4 text-center text-xs text-neutral-500 md:px-6">
        <p>© {new Date().getFullYear()} VFitness · Webs de prueba para el entrenador.</p>
      </div>
    </footer>
  </div>
</Layout>
