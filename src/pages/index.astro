---
import Layout from '../layouts/Layout.astro';
import { SITE, METHOD, PLANS, RECOMMENDED_PLAN_ID } from '../data/vfitness';
import heroLoop from '../assets/hero-loop.mp4';
const orderedPlans = [...PLANS].sort((a, b) => (a.id === RECOMMENDED_PLAN_ID ? -1 : b.id === RECOMMENDED_PLAN_ID ? 1 : 0));
---

<Layout title="VFitness | Cyber-Athlete · Alto Rendimiento" description="Método VFitness. Tecnología y rendimiento. Dietas y entrenos personalizados online.">
  <div class="min-h-screen bg-vfit-black font-mono text-vfit-white antialiased">
    <header class="fixed top-0 z-50 w-full bg-vfit-black/90 backdrop-blur transition-all" id="main-header">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-3 md:px-8">
        <a href="/" class="text-sm font-bold tracking-widest text-vfit-white">VFITNESS</a>
        <nav class="hidden gap-6 text-xs uppercase tracking-wider text-vfit-white/70 md:flex">
          <a href="#metodo">Método</a>
          <a href="#planes">Planes</a>
          <a href="#ubicacion">Ubicación</a>
          <a href="#contacto">Contacto</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="#planes" class="rounded border border-vfit-red px-3 py-2 text-xs font-medium text-vfit-white transition hover:bg-vfit-red hover:text-vfit-white md:inline-flex">INICIAR</a>
          <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center border border-vfit-red/40 text-vfit-white md:hidden" id="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menú">
            <span class="menu-icon-open">≡</span>
            <span class="menu-icon-close hidden">×</span>
          </button>
        </div>
      </div>
      <div class="mobile-nav-panel hidden border-t border-vfit-red/30 bg-vfit-black px-4 py-4 md:hidden" id="mobile-nav">
        <nav class="flex flex-col gap-2 text-xs uppercase tracking-wider">
          <a href="#metodo" class="py-2 text-vfit-white/70 hover:text-vfit-white">Método</a>
          <a href="#planes" class="py-2 text-vfit-white/70 hover:text-vfit-white">Planes</a>
          <a href="#ubicacion" class="py-2 text-vfit-white/70 hover:text-vfit-white">Ubicación</a>
          <a href="#contacto" class="py-2 text-vfit-white/70 hover:text-vfit-white">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="relative min-h-[80vh] overflow-hidden border-b border-vfit-red/20" id="hero">
        <div class="absolute inset-0 z-0 md:p-6">
          <div class="h-full w-full mt-10 overflow-hidden md:rounded-3xl">
            <video id="hero-video" class="h-full w-full object-cover" autoplay loop muted playsinline aria-hidden="true" src={typeof heroLoop === 'string' ? heroLoop : heroLoop.src} />
            <div class="absolute inset-0 bg-vfit-black/75" aria-hidden="true" />
            <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent_0%,rgba(50,0,0,0.16)_50%,transparent_100%)] bg-[length:100%_4px]" style="animation: scan 4s linear infinite;" aria-hidden="true" />
          </div>
        </div>
        <div class="absolute left-0 top-0 h-full w-px bg-vfit-red/30" aria-hidden="true" />
        <div class="absolute right-0 top-0 h-full w-px bg-vfit-red/30" aria-hidden="true" />
        <div class="relative z-[2] flex min-h-[100vh] flex-col justify-center px-4 py-20 md:px-8">
          <div class="mx-auto w-full max-w-4xl">
            <p id="hero-tagline" class="text-[12px] uppercase tracking-[0.5em] text-vfit-red"></p>
            <h1 class="mt-4 font-mono text-3xl font-bold tracking-tight text-vfit-white sm:text-4xl md:text-5xl lg:text-6xl">
              <span class="block text-vfit-white ">RENDIMIENTO</span>
              <span class="block text-vfit-red ">OPTIMIZADO</span>
            </h1>
            <p class="mt-6 max-w-lg text-sm leading-relaxed text-vfit-white/80">
              Método basado en datos. Calorías, macros y plan de entrenamiento específico. Más de 7.000 transformaciones.
            </p>
            <a href="#planes" class="mt-8 inline-block border-2 border-vfit-red px-6 py-3 text-xs font-bold uppercase tracking-widest text-vfit-white transition hover:bg-vfit-red">ACCESO</a>
            <div class="mt-16 flex flex-wrap gap-10 border-t border-vfit-red/30 pt-8">
              <div><p class="text-2xl font-bold tabular-nums text-vfit-red md:text-3xl">7000+</p><p class="mt-0.5 text-[10px] uppercase text-vfit-white/60">CAMBIOS</p></div>
              <div><p class="text-2xl font-bold tabular-nums text-vfit-red md:text-3xl">100%</p><p class="mt-0.5 text-[10px] uppercase text-vfit-white/60">ONLINE</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="metodo" class="border-b border-vfit-red/20 bg-vfit-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-vfit-red md:text-xl">{METHOD.title}</h2>
          <p class="mt-2 text-sm text-vfit-white/80">{METHOD.tagline}</p>
          <ul class="mt-8 space-y-4">
            {METHOD.points.map((point) => (
              <li class="flex gap-3 text-sm text-vfit-white/90">
                <span class="text-vfit-red">›</span>
                <span class="break-words-safe">{point}</span>
              </li>
            ))}
          </ul>
          <div class="mt-10 border border-vfit-red/40 bg-vfit-black/60 p-6">
            <p class="text-2xl font-bold text-vfit-red md:text-3xl">{METHOD.stat}</p>
            <p class="mt-1 text-sm text-vfit-white/80">{METHOD.statLabel}</p>
            <a href="#planes" class="mt-4 inline-block border border-vfit-red px-4 py-2 text-xs font-bold uppercase text-vfit-white hover:bg-vfit-red/10">{METHOD.cta}</a>
          </div>
        </div>
      </section>

      <section id="planes" class="border-b border-vfit-red/20 bg-vfit-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-vfit-red md:text-xl">Planes</h2>
          <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {orderedPlans.map((plan) => {
              const isRec = plan.id === RECOMMENDED_PLAN_ID;
              return (
                <article class={`flex min-w-0 flex-col border p-4 sm:p-5 ${isRec ? 'border-vfit-red bg-vfit-red/10' : 'border-vfit-red/30 bg-vfit-black/80'}`}>
                  {isRec && <span class="mb-2 text-[10px] font-bold uppercase text-vfit-red">RECOMENDADO</span>}
                  <h3 class="font-mono text-sm font-bold text-vfit-white">{plan.name}</h3>
                  <p class="mt-2 font-mono text-xl font-bold text-vfit-red">€{plan.price}<span class="ml-1 text-xs font-normal text-vfit-white/70">{plan.period}</span></p>
                  <p class="mt-2 flex-1 break-words-safe text-xs leading-relaxed text-vfit-white/70">{plan.description}</p>
                  <a href="#contacto" class="mt-4 w-full border border-vfit-red py-2.5 text-center text-xs font-bold uppercase text-vfit-white transition hover:bg-vfit-red">Comprar</a>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="ubicacion" class="border-b border-vfit-red/20 py-14 md:py-20 bg-vfit-black">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-vfit-red">Ubicación</h2>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-vfit-red px-4 py-2 text-sm text-vfit-white hover:bg-vfit-red/10">Google Maps →</a>
        </div>
      </section>

      <section id="instagram" class="border-b border-vfit-red/20 py-14 md:py-20 bg-vfit-black">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-vfit-red">Instagram</h2>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block border border-vfit-red px-4 py-2 text-sm text-vfit-white hover:bg-vfit-red/10">@vfitness_nutricion</a>
          <div class="mt-8 grid grid-cols-3 gap-2 sm:grid-cols-4">
            {[1,2,3,4].map((i) => (
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square border border-vfit-red/30 bg-vfit-black/70 transition hover:border-vfit-red/70"><span class="flex h-full items-center justify-center text-[10px] text-vfit-white/40">[{i}]</span></a>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="bg-vfit-black py-14 md:py-20">
        <div class="mx-auto max-w-6xl px-4 md:px-8">
          <h2 class="font-mono text-lg font-bold uppercase tracking-wider text-vfit-red">Contacto</h2>
          <form class="mt-6 max-w-md space-y-3" aria-label="Contacto">
            <input type="text" name="nombre" placeholder="NOMBRE" class="w-full border border-vfit-red/40 bg-vfit-black px-3 py-2.5 text-sm text-vfit-white placeholder:text-vfit-white/40 focus:border-vfit-red focus:outline-none" />
            <input type="email" name="email" placeholder="EMAIL" class="w-full border border-vfit-red/40 bg-vfit-black px-3 py-2.5 text-sm text-vfit-white placeholder:text-vfit-white/40 focus:border-vfit-red focus:outline-none" />
            <textarea name="mensaje" rows="3" placeholder="MENSAJE" class="w-full border border-vfit-red/40 bg-vfit-black px-3 py-2.5 text-sm text-vfit-white placeholder:text-vfit-white/40 focus:border-vfit-red focus:outline-none" />
            <button type="submit" class="w-full border-2 border-vfit-red py-3 text-xs font-bold uppercase text-vfit-white hover:bg-vfit-red">Enviar</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-vfit-red/30 py-4 bg-vfit-black">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 text-[10px] text-vfit-white/60 md:flex-row md:px-8">
        <p>© {new Date().getFullYear()} VFitness</p>
        <p><a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-vfit-white">Mapa</a> · <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-vfit-white">Instagram</a></p>
      </div>
    </footer>
  </div>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    const heroVideo = document.getElementById('hero-video');
    const heroTagline = document.getElementById('hero-tagline');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => {
        const open = mobileNav.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!open));
        menuBtn.querySelector('.menu-icon-open')?.classList.toggle('hidden', !open);
        menuBtn.querySelector('.menu-icon-close')?.classList.toggle('hidden', open);
      });
      mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mobileNav.classList.add('hidden'); menuBtn?.setAttribute('aria-expanded', 'false'); menuBtn?.querySelector('.menu-icon-open')?.classList.remove('hidden'); menuBtn?.querySelector('.menu-icon-close')?.classList.add('hidden'); }));
    }
    if (heroVideo) {
      heroVideo.addEventListener('loadedmetadata', () => {
        try {
          if (heroVideo.currentTime < 2) heroVideo.currentTime = 2;
        } catch (e) {}
      });
    }
    if (heroTagline) {
      const phrases = [
        '// V_SYSTEM_ONLINE',
        '// DATA_DRIVEN_COACHING',
        '// ALTO_RENDIMIENTO_24/7',
        '// INPUT_DISCIPLINA → OUTPUT_RESULTADOS',
      ];
      let idx = 0;
      const updateTagline = () => {
        heroTagline.textContent = phrases[idx];
        idx = (idx + 1) % phrases.length;
      };
      updateTagline();
      setInterval(updateTagline, 2600);
    }
  </script>
  <style is:global>
    @keyframes scan {
      0%, 100% { background-position: 0 -100%; }
      50% { background-position: 0 200%; }
    }
  </style>
</Layout>

